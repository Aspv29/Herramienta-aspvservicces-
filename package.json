{
  "name": "aspvservices",
  "version": "2.0.0",
  "description": "AspvServices - Herramienta Profesional de Servicio para Dispositivos Moviles 2026",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "cli": "node src/cli.js",
    "build": "electron-builder --config config/electron-builder.json",
    "build:win": "electron-builder --win --x64 --config config/electron-builder.json",
    "build:portable": "electron-builder --win portable --x64 --config config/electron-builder.json",
    "pack": "electron-builder --dir --config config/electron-builder.json",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "mobile",
    "unlock",
    "frp",
    "mdm",
    "firmware",
    "android",
    "iphone",
    "samsung",
    "xiaomi",
    "huawei",
    "motorola",
    "qualcomm",
    "mediatek",
    "carrier-unlock",
    "device-service"
  ],
  "author": "AspvServices Team",
  "license": "Proprietary",
  "dependencies": {
    "axios": "^1.7.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  }
}
